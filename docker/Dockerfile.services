FROM nvidia/cuda:13.1.0-runtime-ubuntu24.04 AS base

ARG DEBIAN_FRONTEND=noninteractive

ENV TZ=Etc/UTC
ENV PIP_DISABLE_PIP_VERSION_CHECK=1
ENV PIP_NO_CACHE_DIR=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /workspace

ENV VIRTUAL_ENV=/opt/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
ENV PYTHONPATH=/workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    g++ \
    curl \
    wget \
    git \
    ffmpeg \
    libsm6 \
    libxext6 \
    libx11-6 \
    libgl1 \
    libgl1-mesa-dev \
    libssl-dev \
    python3-gdcm \
    libjpeg-dev \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /tmp/requirements.txt

RUN python3 -m venv "$VIRTUAL_ENV" && \
    python3 -m pip install --upgrade pip setuptools wheel && \
    grep -vE '^\s*gdcm\s*([><=].*)?$' /tmp/requirements.txt > /tmp/requirements.docker.txt && \
    pip install -r /tmp/requirements.docker.txt && \
    pip install fastapi "uvicorn[standard]" python-multipart requests

FROM base AS yolox_runtime
COPY . /workspace
RUN pip install -r /workspace/MyYoloX/myyolox_api/requirements.txt && \
    pip install --no-build-isolation -e /workspace/MyYoloX

FROM base AS maseg_runtime
COPY . /workspace
RUN grep -vE '^\s*gdcm\s*([><=].*)?$' /workspace/BreastSegmentationUnet/breastSegmentation_api/requirements.txt > /tmp/maseg.requirements.docker.txt && \
    pip install -r /tmp/maseg.requirements.docker.txt && \
    pip install SimpleITK

FROM base AS notebook_runtime
COPY . /workspace
RUN pip install -r /workspace/MyYoloX/myyolox_api/requirements.txt && \
    pip install --no-build-isolation -e /workspace/MyYoloX && \
    grep -vE '^\s*gdcm\s*([><=].*)?$' /workspace/BreastSegmentationUnet/breastSegmentation_api/requirements.txt > /tmp/maseg.notebook.requirements.txt && \
    pip install -r /tmp/maseg.notebook.requirements.txt

FROM notebook_runtime AS notebook
CMD ["jupyter", "lab", "--ip=0.0.0.0", "--port=8888", "--no-browser", "--allow-root"]

FROM yolox_runtime AS yolox_api
CMD ["uvicorn", "common_tasks.serve.yolox_api:app", "--host", "0.0.0.0", "--port", "8001"]

FROM maseg_runtime AS maseg_api
CMD ["uvicorn", "common_tasks.serve.maseg_api:app", "--host", "0.0.0.0", "--port", "8002"]
